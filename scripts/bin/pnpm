#!/bin/bash
# Lazy wrapper for pnpm

# Remove ourselves from PATH temporarily to avoid recursion
WRAPPER_DIR="$(dirname "$(readlink -f "$0")")"
export PATH="${PATH//$WRAPPER_DIR:/}"

# Load nvm which sets up pnpm in PATH
. "$WRAPPER_DIR/nvmload" &> /dev/null

# Now call the real pnpm
exec pnpm "$@"
