#!/bin/bash
# Lazy wrapper for nvm

# Remove ourselves from PATH temporarily to avoid recursion
WRAPPER_DIR="$(dirname "$(readlink -f "$0")")"
export PATH="${PATH//$WRAPPER_DIR:/}"

# Load nvm (nvmload is in the same directory as this wrapper)
. "$WRAPPER_DIR/nvmload"

# Now call nvm (which should be a function)
nvm "$@"
