#!/bin/bash
# Lazy wrapper for rbenv

# Remove ourselves from PATH temporarily to avoid recursion
WRAPPER_DIR="$(dirname "$(readlink -f "$0")")"
export PATH="${PATH//$WRAPPER_DIR:/}"

# Load rbenv (rbenvload is in the same directory as this wrapper)
. "$WRAPPER_DIR/rbenvload"

# Now call rbenv (which should be available)
rbenv "$@"
