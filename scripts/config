#!/bin/bash

set -euo pipefail

BIN_DEST="$HOME/.local/bin"
RBENV_DEST="$HOME/.local/bin/rbenvload"
NVM_DEST="$HOME/.local/bin/nvmload"
SCRIPT_DIR="$(pwd)/scripts"
USER_SHELL="$(basename "$SHELL")"
RC_FILE=""

case "$USER_SHELL" in
    bash) RC_FILE="$HOME/.bashrc" ;;
    zsh)  RC_FILE="$HOME/.zshrc"  ;;
    fish) RC_FILE="$HOME/.config/fish/config.fish" ;;
    ksh)  RC_FILE="$HOME/.kshrc" ;;
    tcsh) RC_FILE="$HOME/.tcshrc" ;;
    csh)  RC_FILE="$HOME/.cshrc" ;;
    dash) RC_FILE="$HOME/.profile" ;;
    sh)   RC_FILE="$HOME/.profile" ;;
    *)
        echo "Unsupported shell: $USER_SHELL"
        echo "Please manually add $BIN_DEST to your PATH."
        exit 1
    ;;
esac
